<mujoco model="hackathon_icu">
  <statistic center="0 0 1" extent="4"/>

  <visual>
    <headlight diffuse="0.8 0.8 0.8" ambient="0.4 0.4 0.4" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.9 0.9 0.9" rgb2="0.7 0.7 0.7" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.85 0.85 0.9" rgb2="0.8 0.8 0.85" markrgb="0.7 0.7 0.7" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.05"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="5 5 0.05" type="plane" material="groundplane"/>

    <!-- add  wall1  -->
    <body name="wall1" pos="0 3.1 2.3">
      <geom type="box" size="5 0.1 2.3" rgba="0.9 0.95 0.95 1"/>
    </body>

    <!-- add  wall2  -->
    <body name="wall2" pos="0 -3.1 2.3">
      <geom type="box" size="5 0.1 2.3" rgba="0.9 0.95 0.95 1"/>
    </body>

    <!-- add  bed  -->
    <body name="bed" pos="-2.5 1.5 0.4">
      <geom type="box" size="1 1.5 0.4" rgba="0.4 0.6 0.8 1"/>
    </body>

    <!-- add  ecg  -->
    <body name="vitals_monitor" pos="0 2.7 1.2">
      <geom type="box" size="0.4 0.2 0.3" rgba="0.2 0.2 0.2 1"/>
      <geom type="box" size="0.3 0.21 0.2" pos="0 -0.01 0" rgba="0.1 0.8 0.3 1"/>
    </body>

    <body name="camera_mount" pos="0 -2.7 2.5">
      <joint name="camera_pan" type="hinge" axis="0 0 1" range="-90 90" limited="true" damping="0.5"/>
      <geom type="cylinder" size="0.1 0.05" rgba="0.5 0.3 0.3 1"/>
      
      <body name="camera_head" pos="0 0.1 0">
        <joint name="camera_tilt" type="hinge" axis="1 0 0" range="-45 45" limited="true" damping="0.5"/>
        <geom type="box" size="0.08 0.1 0.08" rgba="0.1 0.1 0.1 1"/>
        <camera name="robot_camera" pos="0 0.1 0" euler="60 0 0"/>
      </body>
    </body>

  </worldbody>

  <actuator>
    <position name="pan_motor" joint="camera_pan" ctrlrange="-1.57 1.57" kp="10"/>
    <position name="tilt_motor" joint="camera_tilt" ctrlrange="-0.78 0.78" kp="10"/>
  </actuator>
  
</mujoco>

















